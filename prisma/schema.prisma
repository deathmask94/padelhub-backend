generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model match_players {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  match_id             String        @db.Uuid
  user_id              String        @db.Uuid
  team                 team_side     @default(team_a)
  status               player_status @default(pending)
  joined_at            DateTime      @default(now()) @db.Timestamp(6)
  result_confirmed     Boolean       @default(false)
  result_confirmed_at  DateTime?     @db.Timestamp(6)
  matches   matches       @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     users         @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@unique([match_id, user_id], map: "uq_match_player")
  @@index([match_id], map: "idx_match_players_match")
  @@index([status], map: "idx_match_players_status")
  @@index([user_id], map: "idx_match_players_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model match_results {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  match_id       String      @unique @db.Uuid
  registered_by  String      @db.Uuid
  organizer_team winner_team?
  score_team_a   String      @db.VarChar(20)
  score_team_b   String      @db.VarChar(20)
  winner         winner_team
  registered_at  DateTime    @default(now()) @db.Timestamp(6)
  confirmed_by   String?     @db.Uuid
  confirmed_at   DateTime?   @db.Timestamp(6)
  matches        matches     @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users       @relation(fields: [registered_by], references: [id], onUpdate: NoAction)

  @@index([match_id], map: "idx_match_results_match")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model matches {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizer_id  String          @db.Uuid
  club          String          @db.VarChar(200)
  format        match_format    @default(doubles)
  status        match_status    @default(open)
  gender_preference gender?
  is_ranked     Boolean         @default(true)
  match_date    DateTime        @db.Date
  match_time    DateTime        @db.Time(6)
  created_at    DateTime        @default(now()) @db.Timestamp(6)
  updated_at    DateTime        @default(now()) @db.Timestamp(6)
  match_players   match_players[]
  match_results   match_results?
  mmr_history     mmr_history[]
  match_reminders match_reminders[]
  player_ratings  player_ratings[]
  users           users           @relation(fields: [organizer_id], references: [id], onUpdate: NoAction)

  @@index([match_date], map: "idx_matches_date")
  @@index([organizer_id], map: "idx_matches_organizer")
  @@index([status], map: "idx_matches_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model mmr_history {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  match_id      String?  @db.Uuid
  mmr_before    Int
  mmr_after     Int
  delta         Int      @default(dbgenerated("(mmr_after - mmr_before)"))
  calculated_at DateTime @default(now()) @db.Timestamp(6)
  matches       matches? @relation(fields: [match_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, match_id], map: "uq_mmr_per_match_user")
  @@index([match_id], map: "idx_mmr_history_match")
  @@index([user_id, calculated_at(sort: Desc)], map: "idx_mmr_history_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refresh_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique @db.VarChar(512)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_refresh_tokens_exp")
  @@index([user_id], map: "idx_refresh_tokens_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rut                   Int
  dv_rut                String                  @db.Char(1)
  email                 String?                 @unique @db.VarChar(255)
  phone                 String                  @unique @db.VarChar(20)
  name                  String                  @db.VarChar(100)
  last_name             String?                 @db.VarChar(25)
  username              String?                 @unique @db.VarChar(25)
  username_changed_at   DateTime?               @db.Timestamp(6)
  password_hash         String                  @db.VarChar(255)
  photo_url             String?                 @db.VarChar(500)
  birth_date            DateTime?               @db.Date
  level                 user_level              @default(tercera)
  gender                gender?
  zone                  String                  @db.VarChar(100)
  mmr                   Int                     @default(1000)
  role                  user_role               @default(player)
  is_active             Boolean                 @default(true)
  reminder_enabled      Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  updated_at            DateTime                @default(now()) @db.Timestamp(6)
  match_players         match_players[]
  match_results         match_results[]
  matches               matches[]
  mmr_history           mmr_history[]
  refresh_tokens        refresh_tokens[]
  password_reset_tokens password_reset_tokens[]
  match_reminders       match_reminders[]
  admin_audit_logs      admin_audit_logs[]
  ratings_given         player_ratings[]   @relation("ratings_given")
  ratings_received      player_ratings[]   @relation("ratings_received")
  notifications         notifications[]
  push_tokens           push_tokens[]

  @@unique([rut, dv_rut], map: "uq_rut")
  @@index([email], map: "idx_users_email")
  @@index([is_active], map: "idx_users_active")
  @@index([level], map: "idx_users_level")
  @@index([mmr(sort: Desc)], map: "idx_users_mmr")
  @@index([rut], map: "idx_users_rut")
  @@index([zone], map: "idx_users_zone")
}

model match_reminders {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  match_id String   @db.Uuid
  user_id  String   @db.Uuid
  type     String   @db.VarChar(5) // "24h" | "1h"
  sent_at  DateTime @default(now()) @db.Timestamp(6)
  matches  matches  @relation(fields: [match_id], references: [id], onDelete: Cascade)
  users    users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([match_id, user_id, type])
  @@index([match_id], map: "idx_match_reminders_match")
  @@index([user_id],  map: "idx_match_reminders_user")
}

model player_ratings {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  match_id    String   @db.Uuid
  rater_id    String   @db.Uuid
  rated_id    String   @db.Uuid
  fair_play   Int
  punctuality Int
  skill_level Int
  created_at  DateTime @default(now()) @db.Timestamp(6)
  matches     matches  @relation(fields: [match_id], references: [id], onDelete: Cascade)
  rater       users    @relation("ratings_given",    fields: [rater_id], references: [id], onDelete: Cascade)
  rated       users    @relation("ratings_received", fields: [rated_id], references: [id], onDelete: Cascade)

  @@unique([match_id, rater_id, rated_id])
  @@index([rated_id], map: "idx_ratings_rated")
  @@index([match_id], map: "idx_ratings_match")
}

model admin_audit_logs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_id   String   @db.Uuid
  action     String   @db.VarChar(50)
  details    String?  @db.Text
  ip         String?  @db.VarChar(45)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id],   map: "idx_audit_admin")
  @@index([created_at], map: "idx_audit_date")
}

model password_reset_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique @db.VarChar(512)
  expires_at DateTime @db.Timestamp(6)
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token], map: "idx_prt_token")
  @@index([user_id], map: "idx_prt_user")
}

model notifications {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  title      String   @db.VarChar(200)
  body       String?  @db.Text
  read       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at(sort: Desc)], map: "idx_notif_user")
}

model push_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique @db.VarChar(512)
  platform   String   @default("android") @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_push_tokens_user")
}

enum match_format {
  doubles
  singles
}

enum match_status {
  open
  confirmed
  in_progress
  finished
  cancelled
}

enum player_status {
  pending
  confirmed
  rejected
  removed
}

enum team_side {
  team_a
  team_b
}

enum user_level {
  primera  @map("1ra")
  segunda  @map("2da")
  tercera  @map("3ra")
  cuarta  @map("4ta")
  quinta  @map("5ta")
  sexta  @map("6ta")
  septima_mas @map("7ma+")
}

enum user_role {
  player
  admin
}

enum gender {
  Masculino
  Femenino
}

enum winner_team {
  team_a
  team_b
  draw
}
